<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.TextField?>
<?import com.sun.javafx.charts.Legend?>
<?import javafx.scene.layout.AnchorPane?>
<AnchorPane prefHeight="260.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.lr3.HelloController">
    <children>
<HBox xmlns:fx="http://javafx.com/fxml"
      spacing="10.0"
      alignment="TOP_CENTER">
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>

    <!-- Колонка 1: Исходный текст -->
    <VBox spacing="5.0" alignment="CENTER">
        <Label text="Исходный текст"/>
        <TextArea fx:id="inputTextEnc"
                  promptText="Введите исходный текст..."
                  prefHeight="100.0"
                  maxHeight="150.0"
                  minHeight="100.0"
                  minWidth="200.0"/>
    </VBox>

    <!-- Колонка 2: Кнопки -->
    <VBox spacing="10.0" alignment="CENTER">
        <Label text="F функция: арифметический сдвиг вправо"/>
        <Label text="Количество раундов:"/>
        <TextField fx:id="roundCountEnc"/>
        <Label text="Ключ:"/>
        <TextField fx:id="encryptKey"/>
        <Button fx:id="encryptButton" text="Зашифровать" onAction="#onEncryptButtonClick"  minWidth="120.0"/>
    </VBox>

    <!-- Колонка 3: Зашифрованный текст -->
    <VBox spacing="5.0" alignment="CENTER">
        <Label text="Зашифрованный текст"/>
        <TextArea fx:id="outputTextEnc"
                  promptText="Результат появится здесь"
                  editable="true"
                  prefHeight="30.0"
                  maxHeight="150.0"
                  minHeight="100.0"/>
        <TextArea fx:id="outputTextEncLog"
                  promptText="Результат появится здесь"
                  editable="true"
                  prefHeight="100.0"
                  maxHeight="300.0"
                  minHeight="100.0"/>
    </VBox>
</HBox>
        <Label fx:id="encryptfooterMessage"
               AnchorPane.bottomAnchor="10.0"
               AnchorPane.leftAnchor="10.0"
               AnchorPane.rightAnchor="10.0"
               style="-fx-alignment: center;"/>
    </children>
</AnchorPane>